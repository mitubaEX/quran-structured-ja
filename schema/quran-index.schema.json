{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/quran-index.schema.json",
  "title": "Quran Structured JA Index",
  "type": "object",
  "required": [
    "project",
    "included_surahs"
  ],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "required": [
        "title",
        "language",
        "version",
        "policy_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "policy_summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "included_surahs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "surah",
          "chapter_name_ar",
          "chapter_name_ja",
          "chapter_name_en",
          "ayah_count_total",
          "ayah_count_included",
          "is_partial",
          "file"
        ],
        "additionalProperties": false,
        "properties": {
          "surah": {
            "type": "integer",
            "minimum": 1
          },
          "chapter_name_ar": {
            "type": "string",
            "minLength": 1
          },
          "chapter_name_ja": {
            "type": "string",
            "minLength": 1
          },
          "chapter_name_en": {
            "type": "string",
            "minLength": 1
          },
          "ayah_count_total": {
            "type": "integer",
            "minimum": 1
          },
          "ayah_count_included": {
            "type": "integer",
            "minimum": 1
          },
          "is_partial": {
            "type": "boolean"
          },
          "file": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
