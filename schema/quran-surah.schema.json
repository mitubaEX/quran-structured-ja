{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/quran-surah.schema.json",
  "title": "Quran Structured JA Surah",
  "type": "object",
  "required": [
    "surah",
    "chapter_name_ar",
    "chapter_name_ja",
    "chapter_name_en",
    "traditional_order",
    "ayah_count_total",
    "ayah_count_included",
    "is_partial",
    "approximate_theme",
    "summary_ja",
    "ayahs"
  ],
  "additionalProperties": false,
  "properties": {
    "surah": {
      "type": "integer",
      "minimum": 1
    },
    "chapter_name_ar": {
      "type": "string",
      "minLength": 1
    },
    "chapter_name_ja": {
      "type": "string",
      "minLength": 1
    },
    "chapter_name_en": {
      "type": "string",
      "minLength": 1
    },
    "traditional_order": {
      "type": "integer",
      "minimum": 1
    },
    "ayah_count_total": {
      "type": "integer",
      "minimum": 1
    },
    "ayah_count_included": {
      "type": "integer",
      "minimum": 1
    },
    "is_partial": {
      "type": "boolean"
    },
    "approximate_theme": {
      "type": "string",
      "minLength": 1
    },
    "summary_ja": {
      "type": "string",
      "minLength": 1
    },
    "coverage_note": {
      "type": "string",
      "minLength": 1
    },
    "ayahs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ayah",
          "literal_ja",
          "modern_ja",
          "summary_ja",
          "themes",
          "notes",
          "caution"
        ],
        "additionalProperties": false,
        "properties": {
          "ayah": {
            "type": "integer",
            "minimum": 1
          },
          "arabic": {
            "type": "string",
            "minLength": 1
          },
          "romanized": {
            "type": "string",
            "minLength": 1
          },
          "literal_ja": {
            "type": "string",
            "minLength": 1
          },
          "modern_ja": {
            "type": "string",
            "minLength": 1
          },
          "summary_ja": {
            "type": "string",
            "minLength": 1
          },
          "themes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "caution": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
